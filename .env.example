# ToxicFlow Passport — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local or any file containing real secrets.

# ── Blockchain ────────────────────────────────────────────────────────────────
# RPC endpoint for Sepolia testnet (server-side)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# RPC endpoint exposed to the frontend (Vite public)
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Deployed contract addresses ───────────────────────────────────────────────
# These are the Sepolia testnet addresses. Update after each redeployment.
VITE_PASSPORT_REGISTRY=0x101fd25Ff9B9EBC21359B15F0cdE8aD7C4f01D0e
VITE_TOXIC_FLOW_HOOK=0x024245B2CDBccf9581D1f6FbA533ca4061410080
VITE_POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
VITE_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
VITE_POOL_ID=0x7cd5aa906aadff2d0776a1c7fed113e19284420876110f9de18399546cf2148d

# ── Deployer keys (server-side only — never expose to client) ─────────────────
# Deployer EOA: used for forge broadcast scripts and admin tier operations
DEPLOYER_PRIVATE_KEY=

# Scorer/oracle key: used for automated tier updates
SCORER_PRIVATE_KEY=

# 0G storage signer: used for evidence anchoring
ZG_SIGNER_PRIVATE_KEY=

# ── KeeperHub automation ──────────────────────────────────────────────────────
KEEPERHUB_API_URL=https://api.keeperhub.io
KEEPERHUB_API_KEY=
KEEPERHUB_WORKFLOW_ID=

# ── Application behaviour ─────────────────────────────────────────────────────
# Set DEMO_MODE=true to enable POST /api/demo/set-tier (disable in production)
DEMO_MODE=false

# Whether PassportRegistry supports self-registration (selfRegister() function)
VITE_SELF_REGISTER_DEPLOYED=true

# ── Server ────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string
PORT=8080
