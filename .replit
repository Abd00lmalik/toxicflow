modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21495
externalPort = 3000

[userenv]

[userenv.shared]
VITE_PASSPORT_REGISTRY = "0x101fd25Ff9B9EBC21359B15F0cdE8aD7C4f01D0e"
VITE_TOXIC_FLOW_HOOK = "0x024245B2CDBccf9581D1f6FbA533ca4061410080"
VITE_USDC_ADDRESS = "0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238"
VITE_POOL_MANAGER = "0xE03A1074c86CFeDd5C142C4F04F1a1536e203543"
VITE_POOL_SWAP_TEST = "0x9b6b46e2c869aa39918db7f52f5557fe577b6eee"
VITE_SELF_REGISTER_DEPLOYED = "true"
NEXT_PUBLIC_PASSPORT_REGISTRY = "0x101fd25Ff9B9EBC21359B15F0cdE8aD7C4f01D0e"
NEXT_PUBLIC_TOXIC_FLOW_HOOK = "0x024245B2CDBccf9581D1f6FbA533ca4061410080"
NEXT_PUBLIC_USDC_ADDRESS = "0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238"
NEXT_PUBLIC_POOL_MANAGER = "0xE03A1074c86CFeDd5C142C4F04F1a1536e203543"
VITE_POOL_ID = "0x7cd5aa906aadff2d0776a1c7fed113e19284420876110f9de18399546cf2148d"
NEXT_PUBLIC_POOL_ID = "0x7cd5aa906aadff2d0776a1c7fed113e19284420876110f9de18399546cf2148d"
