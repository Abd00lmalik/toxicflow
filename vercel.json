{
  "buildCommand": "pnpm --filter @workspace/toxicflow run build",
  "outputDirectory": "artifacts/toxicflow/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "env": {
    "BASE_PATH": "/"
  },
  "functions": {
    "api/**/*.ts": {}
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
